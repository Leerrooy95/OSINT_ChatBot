# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Flask session key ────────────────────────────────────────────────────────
# Encrypts session cookies.  Auto-generated at startup if omitted, but a
# random value on every restart will log every user out.  Set a fixed,
# long random string in production so sessions survive restarts.
# FLASK_SECRET_KEY=change-me-to-a-long-random-string

# ── Claude model ─────────────────────────────────────────────────────────────
# (Optional) Override the default Claude model used for chat requests.
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Rate limiting storage ────────────────────────────────────────────────────
# The default in-process memory:// backend is fine for local development and
# single-process deployments, but breaks when gunicorn runs multiple workers:
# each worker maintains its own counter, so a user could multiply the allowed
# rate by the number of workers.
#
# For accurate cross-worker rate limiting, point this at a Redis instance:
# RATELIMIT_STORAGE_URI=redis://localhost:6379/0
#
# On Render: add a Redis (Key Value) service, then copy its Internal URL here.
# (Redis is not available on Render's free tier — upgrade to starter or use
# an external Redis provider such as Upstash for a free Redis instance.)

# ── Debug mode ───────────────────────────────────────────────────────────────
# NEVER enable debug mode in production — it exposes an interactive debugger
# and disables several security features.  Only set this locally.
# FLASK_DEBUG=0

# ── NOTE: BYOK (Bring Your Own Key) ─────────────────────────────────────────
# This is a BYOK server.  Users enter their Anthropic API key in the browser.
# No server-side ANTHROPIC_API_KEY or APP_PASSWORD is needed.
