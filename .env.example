# Copy this file to .env and fill in your values
# cp .env.example .env

# Flask session encryption key (auto-generated if omitted, but set a
# fixed value in production so sessions survive restarts)
# FLASK_SECRET_KEY=change-me-to-a-long-random-string

# (Optional) Override the default Claude model
# ANTHROPIC_MODEL=claude-sonnet-4-6

# NOTE: This is a BYOK (Bring Your Own Key) server.
# Users enter their Anthropic API key in the browser.
# No server-side API key or password is required.
